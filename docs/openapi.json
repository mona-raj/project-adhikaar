      "post": {
        "tags": [
          "Recommendations"
        ],
        "operationId": "createReferral",
        "summary": "Create a referral",
        "description": "Creates a referral from an approved recommendation and shares the required information with the selected organization.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
