  "paths": {
    "/help-requests": {
      "post": {
        "tags": [
          "Help Requests"
        ],
        "operationId": "createHelpRequest",
        "summary": "Create a new help request",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "description": {
                    "type": "string",
                    "minLength": 10,
                    "maxLength": 5000
                  },
                  "declaredSafetyStatus": {
                    "type": "string",
                    "enum": [
                      "SAFE",
                      "UNSAFE",
                      "UNKNOWN"
                    ]
                  },
                  "location": {
                    "type": "object",
                    "properties": {
                      "latitude": {
                        "type": "number",
                        "minimum": -90,
                        "maximum": 90
                      },
                      "longitude": {
                        "type": "number",
                        "minimum": -180,
                        "maximum": 180
                      }
                    },
                    "required": [
                      "latitude",
                      "longitude"
                    ]
                  },
                  "contactName": {
                    "type": "string",
                    "minLength": 2,
                    "maxLength": 100
                  },
                  "contactEmail": {
                    "type": "string",
                    "format": "email"
                  },
                  "contactPhone": {
                    "type": "string",
                    "minLength": 8,
                    "maxLength": 20
                  },
                  "preferredLanguageCode": {
                    "type": "string",
                    "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
                  }
                },
                "required": [
                  "description"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Help request created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "helpRequestId": {
                      "type": "string"
                    },
                    "caseId": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string",
                      "enum": [
                        "NEW",
                        "IN_PROGRESS",
                        "COMPLETED",
                        "CLOSED"
                      ]
                    }
                  },
                  "required": [
                    "helpRequestId",
                    "caseId",
                    "status"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid request data."
          },
          "500": {
            "description": "Internal server error."
          }
        }
      }
    },
