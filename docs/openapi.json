                      "type": "string"
                    },
                    "code": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "id",
                    "code",
                    "name"
                  ]
                },
                "organization": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "website": {
                      "type": "string",
                      "nullable": true
                    },
                    "email": {
                      "type": "string",
                      "nullable": true
                    },
                    "phone": {
                      "type": "string",
                      "nullable": true
                    }
                  },
                  "required": [
                    "id",
                    "name",
                    "website",
                    "email",
                    "phone"
                  ]
                }
              },
              "required": [
                "id",
                "status",
                "score",
                "reason",
                "service",
                "organization"
              ]
            }
          }
        },
        "required": [
          "id",
          "status",
          "evaluatedSafetyStatus",
          "helpRequest",
          "services",
          "recommendations"
        ]
      },
      "UpdateCaseServices": {
        "type": "object",
        "properties": {
          "serviceIds": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          }
