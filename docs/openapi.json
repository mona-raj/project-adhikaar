          }
        },
        "required": [
          "id",
          "status",
          "recommendationId",
          "caseId",
          "createdAt"
        ]
      },
      "GetReferralResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "SENT",
              "ACCEPTED",
              "DECLINED",
              "WITHDRAWN",
              "COMPLETED"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "recommendation": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "PENDING",
                  "APPROVED",
                  "REJECTED",
                  "EXPIRED"
                ]
              },
              "score": {
                "type": "number",
                "nullable": true
              },
              "reason": {
                "type": "string",
                "nullable": true
              }
            },
            "required": [
              "id",
              "status",
              "score",
              "reason"
            ]
          },
          "service": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "code": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "code",
              "name"
            ]
          },
          "organization": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "website": {
                "type": "string",
                "nullable": true
              },
              "email": {
                "type": "string",
                "nullable": true
              },
              "phone": {
                "type": "string",
                "nullable": true
              }
            },
            "required": [
              "id",
              "name",
              "website",
              "email",
              "phone"
            ]
          },
          "sharedData": {
            "type": "object",
            "properties": {
              "contact": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "nullable": true
                  },
                  "phone": {
                    "type": "string",
                    "nullable": true
                  }
                },
                "required": [
                  "name",
                  "email",
                  "phone"
                ]
              },
              "helpRequest": {
                "type": "object",
                "properties": {
                  "description": {
                    "type": "string"
                  }
                },
                "required": [
                  "description"
                ]
              },
              "preferredLanguage": {
                "type": "object",
