          "helpRequestId": {
            "type": "string"
          },
          "caseId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "NEW",
              "IN_PROGRESS",
              "COMPLETED",
              "CLOSED"
            ]
          }
        },
        "required": [
          "helpRequestId",
          "caseId",
          "status"
        ]
      },
      "GetCaseResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "NEW",
              "IN_PROGRESS",
              "COMPLETED",
              "CLOSED"
