              "type": "string"
            },
            "code": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "description": {
              "type": "string",
              "nullable": true
            }
          },
          "required": [
            "id",
            "code",
            "name",
            "description"
          ]
        }
      },
      "CreateReferral": {
        "type": "object",
        "properties": {
          "contactName": {
            "type": "string",
            "minLength": 1
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
