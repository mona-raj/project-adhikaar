{
  "openapi": "3.1.0",
  "info": {
    "title": "Project Adhikaar API",
    "version": "1.0.0",
    "description": "REST API for Project Adhikaar - connecting people in need with support organizations."
  },
  "servers": [
    {
      "url": "/api/v1"
    }
  ],
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "status",
          "message"
        ]
      },
      "CreateHelpRequest": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string",
            "minLength": 10,
            "maxLength": 5000
          },
          "declaredSafetyStatus": {
            "type": "string",
            "enum": [
              "SAFE",
              "UNSAFE",
              "UNKNOWN"
            ]
          },
          "location": {
            "type": "object",
            "properties": {
              "latitude": {
                "type": "number",
                "minimum": -90,
                "maximum": 90
              },
              "longitude": {
                "type": "number",
                "minimum": -180,
                "maximum": 180
              }
            },
            "required": [
              "latitude",
              "longitude"
            ]
          },
          "contactName": {
            "type": "string",
            "minLength": 2,
            "maxLength": 100
          },
          "contactEmail": {
            "type": "string",
            "format": "email"
          },
          "contactPhone": {
            "type": "string",
            "minLength": 8,
            "maxLength": 20
          },
          "preferredLanguageCode": {
            "type": "string",
            "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
          }
        },
        "required": [
          "description"
        ]
      },
      "CreateHelpRequestResponse": {
        "type": "object",
